# ==============================================================================
# EduAllocPro — backend/.env.example
# Copy to backend/.env and fill in real values before running the server.
# NEVER commit .env to version control — this file is safe to commit.
# ==============================================================================

# ── Google Cloud Core ──────────────────────────────────────────────────────────
# Your GCP Project ID (not display name). Find: Cloud Console → project selector.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Path to service account JSON. Omit when running on Cloud Run (ADC is automatic).
# Required for local development only.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# GCP region — must match Vertex AI endpoint region.
GCLOUD_REGION=us-central1

# ── Google AI APIs ─────────────────────────────────────────────────────────────
# Gemini API key — obtain from aistudio.google.com → Get API Key
GOOGLE_API_KEY=AIzaSy...

# Vertex AI config — do NOT change model without invalidating embeddings cache
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=textembedding-gecko@003

# Gemini model — do NOT use flash for government briefings
GEMINI_MODEL=gemini-1.5-pro

# Temperature: 0.3 = factual briefings, 0.6 = natural order narrative
GEMINI_TEMPERATURE_BRIEFING=0.3
GEMINI_TEMPERATURE_ORDER=0.6

# ── Google Maps ────────────────────────────────────────────────────────────────
# Restrict key to: Distance Matrix API + Geocoding API only
MAPS_API_KEY=AIzaSy...
MAPS_DISTANCE_MODE=driving

# CRITICAL: Do NOT change this without product-level discussion
MAPS_MAX_COMMUTE_KM=80

# ── BigQuery ───────────────────────────────────────────────────────────────────
BQ_DATASET=edualloc_dataset
BQ_LOCATION=us-central1
BQ_MAX_RESULTS=500
BQ_QUERY_TIMEOUT_S=30

# ── Data Paths (local dev only — not used in Cloud Run) ────────────────────────
# Download UDISE CSV from udiseplus.gov.in → Data Summary → Nandurbar District
UDISE_CSV_PATH=./data/sample/udise_nandurbar.csv
TEACHER_CSV_PATH=./data/sample/teachers_synth.csv
DISTRICT_CODE=NDB01
DISTRICT_NAME=Nandurbar

# ── Cloud Translation ──────────────────────────────────────────────────────────
# Defaults to same GOOGLE_API_KEY — no separate key needed unless quota is hit
TRANSLATE_TARGET_LANG=mr
TRANSLATE_SOURCE_LANG=en

# ── Application Config ─────────────────────────────────────────────────────────
APP_ENV=development
PORT=8000

# CRITICAL: Always 1 — multiple workers break shared embeddings cache in app.state
WORKERS=1

LOG_LEVEL=INFO

# Add production Vercel URL for production env (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Embeddings cache: 24h TTL is sufficient — teacher profiles change rarely
EMBEDDINGS_CACHE_TTL_HOURS=24
EMBEDDINGS_CACHE_MAX_SIZE=10000

# OR-Tools: 20s limit — returns partial result on timeout (HTTP 200, not error)
OPTIMIZER_TIME_LIMIT_S=20

# Briefing cache: 168h = 1 week — briefings are generated weekly
BRIEFING_CACHE_HOURS=168

# ── Firebase Auth ──────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Phase 2 Only — leave commented out in Phase 1 ─────────────────────────────
# HRMS_API_KEY=
# HRMS_API_BASE_URL=
# HRMS_DISTRICT_CODE=
# EARTH_ENGINE_KEY=
# REDIS_URL=redis://localhost:6379
