# ==============================================================================
# EduAllocPro — frontend/.env.example
# Copy to frontend/.env and fill in real values.
# NEVER commit .env to version control — this file is safe to commit.
#
# SECURITY: Only VITE_ prefixed variables are exposed to the browser bundle.
# Never put secret keys or service account credentials here.
# ==============================================================================

# ── API Connection ─────────────────────────────────────────────────────────────
# Backend Cloud Run URL for production. localhost for development.
VITE_API_URL=http://localhost:8000

# 30s timeout accommodates OR-Tools (up to 20s) + Gemini (up to 12s)
VITE_API_TIMEOUT_MS=30000

# ── Google Maps ────────────────────────────────────────────────────────────────
# Restrict this key to your Vercel domain + localhost in Cloud Console.
# Enable: Maps JavaScript API only.
VITE_MAPS_API_KEY=AIzaSy...

# Cloud-hosted map style ID (optional) — creates the dark/muted basemap.
# Create in: Cloud Console → Google Maps → Map Styles
VITE_MAPS_MAP_ID=

# Default map center — Nandurbar district. Adjust per pilot district.
VITE_MAPS_DEFAULT_LAT=21.3661
VITE_MAPS_DEFAULT_LNG=74.2167
VITE_MAPS_DEFAULT_ZOOM=9

# ── Firebase Auth ──────────────────────────────────────────────────────────────
# Firebase Web config — these are public by design (not secrets).
# Obtain from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=

# ── App Behaviour ──────────────────────────────────────────────────────────────
# 'development' shows debug panel + verbose errors. 'production' hides them.
VITE_APP_ENV=development

# Default district for dashboard. Change per state rollout.
VITE_DEFAULT_DISTRICT_ID=NDB01
VITE_DEFAULT_DISTRICT_NAME=Nandurbar

# Default UI language. Overridden per user role at login (BEO → mr).
VITE_DEFAULT_LANGUAGE=en

# Set false only for temporary debugging — Marathi is a first-class feature.
VITE_ENABLE_MARATHI=true

# Schools with UDISE data older than this many months get is_data_stale flag.
VITE_STALE_DATA_THRESHOLD_MONTHS=12

# ── Phase 2 / Optional ────────────────────────────────────────────────────────
# VITE_ENABLE_SATELLITE_LAYER=false
# VITE_SENTRY_DSN=
